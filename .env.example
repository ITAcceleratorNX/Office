# SMTP — отправка заявок с формы
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-mailbox@tmk-limited.com
SMTP_PASS=your-app-password

# Куда приходят заявки (по умолчанию: Yerlepessov.t@tmk-limited.com)
LEAD_TO_EMAIL=Yerlepessov.t@tmk-limited.com

# От кого отправляется письмо (по умолчанию = SMTP_USER)
# LEAD_FROM_EMAIL=your-mailbox@tmk-limited.com

# Примеры:
# Microsoft 365: SMTP_HOST=smtp.office365.com, SMTP_PORT=587, SMTP_SECURE=false
# Yandex:        SMTP_HOST=smtp.yandex.ru, SMTP_PORT=465, SMTP_SECURE=true
